rules_version = "2";
service cloud.firestore {
  match /databases/{database}/documents {
    // Open rules for development - restrict in production
    match /{document=**} {
      allow read, write: if true;
    }

    // Transaction history - read only for authenticated users in production
    match /inventoryTransactions/{document} {
      allow read: if true;
      allow create: if true;
    }

    // Pick tickets collection
    match /pickTickets/{document} {
      allow read, write: if true;
    }

    // Inventory items with batched data
    match /inventoryItems/{document} {
      allow read, write: if true;
    }

    // Orders collection
    match /orders/{document} {
      allow read, write: if true;
    }

    // Counters collection (for sequence numbers)
    match /counters/{document} {
      allow read, write: if true;
    }

    // Bills of Lading collection
    match /billsOfLading/{document} {
      allow read, write: if true;
    }
  }
}